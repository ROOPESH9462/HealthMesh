# ====================================================
# BACKEND API GATEWAY SETTINGS
# ====================================================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database & Cache
MONGO_URI=mongodb://localhost:27017/ai-healthcare
REDIS_URL=redis://localhost:6379

# Authentication & Security
JWT_ACCESS_SECRET=your_super_secret_access_key_change_me_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
PASSWORD_SALT_ROUNDS=12

# Cloud Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Payments (Stripe)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Mailing Services (SMTP / Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@healthcareplatform.com

# External Service Gateways
AI_SERVICE_URL=http://localhost:8000

# Monitoring / Logging
SENTRY_DSN=your_backend_sentry_dsn

# ====================================================
# FRONTEND VITE APP SETTINGS
# ====================================================
VITE_API_URL=http://localhost:5000/api/v1
VITE_SOCKET_URL=http://localhost:5000
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# ====================================================
# AI MICROSERVICE SETTINGS
# ====================================================
AI_HOST=0.0.0.0
AI_PORT=8000
AI_ENV=development
# LLM Integration (Gemini, Hugging Face, etc.)
GEMINI_API_KEY=your_gemini_api_key
HF_API_TOKEN=your_huggingface_api_token
