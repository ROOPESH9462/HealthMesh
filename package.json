{
  "name": "ai-healthcare-platform",
  "version": "1.0.0",
  "description": "Enterprise AI Healthcare Management Platform",
  "private": true,
  "engines": {
    "node": "22.20.0"
  },
  "workspaces": [
    "apps/frontend",
    "apps/backend",
    "packages/shared-types",
    "packages/shared-utils",
    "packages/api-contracts"
  ],
  "scripts": {
    "bootstrap": "npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:ai\"",
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:ai": "cd apps/ai-service && .venv\\Scripts\\activate && python run.py",
    "build:packages": "npm run build --workspace=packages/shared-types --workspace=packages/shared-utils --workspace=packages/api-contracts",
    "build:backend": "npm run build:packages && npm run build --workspace=apps/backend",
    "build:frontend": "npm run build:packages && npm run build --workspace=apps/frontend",
    "test:backend": "npm run test --workspace=apps/backend",
    "test:frontend": "npm run test --workspace=apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
